# Stage 1: Build
FROM golang:1.22-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build \
    -ldflags="-w -s" \
    -o /waf-automator \
    ./cmd/main.go

# Stage 2: Runtime - distroless untuk minimal attack surface
FROM gcr.io/distroless/static-debian12

COPY --from=builder /waf-automator /waf-automator

USER nonroot:nonroot

ENTRYPOINT ["/waf-automator"]