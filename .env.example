# =============================================================================
# WAF AUTOMATOR — Multi-Zone Configuration
# =============================================================================
# cp .env.example .env  →  isi nilainya  →  docker compose up -d
# =============================================================================


# -----------------------------------------------------------------------------
# CLOUDFLARE CREDENTIALS
# API Token permissions yang dibutuhkan (buat di dash.cloudflare.com/profile/api-tokens):
#   - Zone > Zone > Read        ← untuk list semua zone di account
#   - Zone > WAF > Edit         ← untuk toggle rule action
#   - Zone > Analytics > Read   ← untuk fetch RPS via GraphQL
# -----------------------------------------------------------------------------
CF_API_TOKEN=your_cloudflare_api_token_here

# Account ID: Cloudflare Dashboard → kanan bawah → "Account ID"
CF_ACCOUNT_ID=your_account_id_here


# -----------------------------------------------------------------------------
# RULE DISCOVERY
# Automator akan mencari rule dengan nama ini di SEMUA zone secara otomatis.
# Nilai harus sama persis dengan kolom "Name" rule di Cloudflare dashboard.
# Default sudah sesuai dengan screenshot struktur WAF yang diberikan.
# -----------------------------------------------------------------------------
ALLOW_RULE_NAME=allow-countries-ip

# Zone yang DIKECUALIKAN dari automasi (opsional).
# Gunakan untuk staging, internal, atau domain yang tidak perlu diproteksi.
# Format: comma-separated domain names (tanpa spasi berlebih)
# Contoh: EXCLUDED_ZONES=staging.clienta.com,internal.clientb.com
EXCLUDED_ZONES=


# -----------------------------------------------------------------------------
# THRESHOLD & TIMING
# -----------------------------------------------------------------------------

# Batas RPS sebelum mitigasi aktif. Berlaku sama untuk semua domain.
# Sesuaikan dengan baseline traffic normal klien kamu.
RPS_THRESHOLD=1000

# Berapa menit RPS harus terus breach sebelum mitigasi di-trigger.
# Lebih besar = lebih toleran terhadap spike sementara, lebih lambat respons.
TRIGGER_DURATION_MINUTES=2

# Berapa menit RPS harus stabil di bawah threshold sebelum rule dikembalikan ke skip.
# Jangan terlalu pendek — attacker bisa pause lalu lanjut lagi.
COOLDOWN_DURATION_MINUTES=15

# Interval polling ke Cloudflare Analytics API (dalam detik). Minimum: 30.
POLL_INTERVAL_SECONDS=60

# Seberapa sering service re-fetch daftar zone dari Cloudflare (dalam jam).
# Berguna agar domain baru yang ditambahkan ke account otomatis terdeteksi
# tanpa harus restart service.
ZONE_REFRESH_HOURS=1


# -----------------------------------------------------------------------------
# TELEGRAM NOTIFIER
# Jika diisi, keduanya wajib diisi bersama.
# -----------------------------------------------------------------------------

# Token dari @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ

# Chat ID group (selalu angka negatif untuk group/supergroup)
# Cara ambil:
#   1. Add bot ke group
#   2. Kirim pesan apapun di group
#   3. curl "https://api.telegram.org/bot<TOKEN>/getUpdates" | jq '.result[].message.chat | {id,title}'
TELEGRAM_CHAT_ID=-1001234567890


# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
# "info"  → log normal (recommended untuk production)
# "debug" → verbose, log setiap detail API call (untuk troubleshooting)
LOG_LEVEL=info