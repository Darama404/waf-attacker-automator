# =============================================================================
# WAF AUTOMATOR — Environment Configuration
# =============================================================================
# Salin file ini menjadi .env lalu isi dengan nilai yang sebenarnya:
#   cp .env.example .env
#
# JANGAN commit file .env ke repository (sudah ada di .gitignore)
# =============================================================================


# -----------------------------------------------------------------------------
# CLOUDFLARE CREDENTIALS (semua wajib diisi)
# -----------------------------------------------------------------------------

# API Token dengan permission:
#   - Zone > WAF > Edit
#   - Zone > Analytics > Read
# Buat di: https://dash.cloudflare.com/profile/api-tokens
CF_API_TOKEN=your_cloudflare_api_token_here

# Zone ID domain yang diproteksi
# Cara ambil: Cloudflare Dashboard → pilih domain → kanan bawah → "Zone ID"
CF_ZONE_ID=your_zone_id_here

# Account ID Cloudflare
# Cara ambil: Cloudflare Dashboard → kanan bawah → "Account ID"
CF_ACCOUNT_ID=your_account_id_here

# Custom WAF Ruleset ID
# Cara ambil (jalankan perintah ini):
#   curl -X GET "https://api.cloudflare.com/client/v4/zones/ZONE_ID/rulesets" \
#     -H "Authorization: Bearer YOUR_TOKEN" \
#     | jq '.result[] | select(.phase=="http_request_firewall_custom") | {id, name}'
CF_RULESET_ID=your_ruleset_id_here

# Rule ID spesifik untuk rule "allow" yang akan di-toggle
# Cara ambil (jalankan perintah ini):
#   curl -X GET "https://api.cloudflare.com/client/v4/zones/ZONE_ID/rulesets/RULESET_ID" \
#     -H "Authorization: Bearer YOUR_TOKEN" \
#     | jq '.result.rules[] | {id, description, action}'
CF_RULE_ID=your_allow_rule_id_here


# -----------------------------------------------------------------------------
# THRESHOLD & TIMING
# -----------------------------------------------------------------------------

# Batas RPS sebelum mitigasi aktif
# Default: 1000
RPS_THRESHOLD=1000

# Berapa menit RPS harus terus breach sebelum mitigasi di-trigger
# Default: 2
# Tips: Jangan terlalu kecil (1 menit) untuk menghindari false positive
TRIGGER_DURATION_MINUTES=2

# Berapa menit RPS harus stabil di bawah threshold sebelum rule dikembalikan ke skip
# Default: 15
# Tips: Jangan terlalu pendek — attacker bisa pause sebentar lalu lanjut lagi
COOLDOWN_DURATION_MINUTES=15

# Interval polling ke Cloudflare API (dalam detik)
# Default: 60 | Minimum: 30 (di bawah ini akan ditolak saat startup)
# Tips: Jangan terlalu kecil karena Cloudflare GraphQL punya rate limit
POLL_INTERVAL_SECONDS=60


# -----------------------------------------------------------------------------
# TELEGRAM NOTIFIER (opsional)
# Jika diisi, keduanya wajib diisi bersama — tidak boleh salah satu saja
# -----------------------------------------------------------------------------

# Bot token dari @BotFather di Telegram
# Cara buat: chat @BotFather → /newbot → ikuti instruksi
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ

# Chat ID group Telegram tujuan notifikasi
# PENTING: Chat ID group selalu berupa angka negatif, contoh: -1001234567890
#
# Cara ambil Chat ID:
#   1. Tambahkan bot ke group
#   2. Kirim pesan apapun di group
#   3. Jalankan perintah ini:
#      curl "https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates" \
#        | jq '.result[].message.chat | {id, title, type}'
#   4. Ambil nilai "id" yang bertipe "group" atau "supergroup"
TELEGRAM_CHAT_ID=-1001234567890


# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------

# Level log: "info" (default) atau "debug" (verbose, untuk troubleshooting)
# Mode debug akan mencetak detail query GraphQL, response API, dll.
LOG_LEVEL=info
