# Cloudflare Credentials
CF_API_TOKEN=your_cloudflare_api_token_with_WAF_edit_permission
CF_ZONE_ID=your_zone_id
CF_ACCOUNT_ID=your_account_id

# Dapatkan Ruleset ID dan Rule ID via:
# GET https://api.cloudflare.com/client/v4/zones/{zone_id}/rulesets
CF_RULESET_ID=your_custom_ruleset_id
CF_RULE_ID=your_allow_rule_id

# Threshold Configuration
RPS_THRESHOLD=1000
TRIGGER_DURATION_MINUTES=2
COOLDOWN_DURATION_MINUTES=15
POLL_INTERVAL_SECONDS=60

# Opsional: Slack alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz